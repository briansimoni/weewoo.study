{
  "unstable": ["kv", "cron"],
  "lock": false,
  "tasks": {
    "check": "deno fmt --check && deno lint && deno check **/*.ts && deno check **/*.tsx",
    "cli": "echo \"import '\\$fresh/src/dev/cli.ts'\" | deno run --unstable-* -A -",
    "manifest": "deno task cli manifest $(pwd)",
    "dev": "deno task tailwind & deno run --tunnel -A --inspect --watch=static/,routes/ --unstable-kv --unstable-cron dev.ts",
    "start": "deno run -A --unstable-cron main.ts",
    "build": "deno task build:css && deno run -A --unstable-kv dev.ts build",
    "preview": "deno run -A --unstable-cron main.ts",
    "update": "deno run -A -r https://fresh.deno.dev/update .",
    "tailwind": "deno run -A npm:@tailwindcss/cli --input ./static/styles.css --output ./static/dist.css --watch",
    "build:css": "deno run -A npm:@tailwindcss/cli --input ./static/styles.css --output ./static/dist.css --minify",
    "test": "deno test --ignore=image-converter,node_modules,.deno_cache"
  },
  "lint": {
    "rules": {
      "tags": ["fresh", "recommended"]
    }
  },
  "exclude": ["**/_fresh/*", "image-converter/**/*"],
  "nodeModulesDir": "auto",
  "imports": {
    "$fresh/": "https://deno.land/x/fresh@1.7.3/",
    "@deno-library/logger": "jsr:@deno-library/logger@^1.1.9",
    "@openai/openai": "jsr:@openai/openai@^4.102.0",
    "@std/assert": "jsr:@std/assert@^1.0.13",
    "@std/csv": "jsr:@std/csv@^1.0.5",
    "@std/expect": "jsr:@std/expect@^1.0.17",
    "@std/http": "jsr:@std/http@^1.0.13",
    "@std/testing": "jsr:@std/testing@^1.0.9",
    "@tailwindcss/cli": "npm:@tailwindcss/cli@^4.0.9",
    "chart.js": "npm:chart.js@^4.5.0",
    "cron-time-generator": "npm:cron-time-generator@^2.0.3",
    "dayjs": "npm:dayjs@^1.11.13",
    "dayjs-plugin-utc": "npm:dayjs-plugin-utc@^0.1.2",
    "jszip": "npm:jszip@^3.10.1",
    "preact": "npm:preact@^10.27.1",
    "preact/signals": "npm:@preact/signals@2.0.1",
    "lucide-preact": "npm:lucide-preact@^0.477.0",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "microdiff": "npm:microdiff@^1.0.0",
    "sharp": "npm:sharp@^0.34.3",
    "stripe": "npm:stripe@22.0.1",
    "tailwindcss": "npm:tailwindcss@4.0.9",
    "tailwindcss/": "npm:/tailwindcss@4.0.9/",
    "tailwindcss/plugin": "npm:/tailwindcss@4.0.9/plugin",
    "daisyui": "npm:daisyui@5.0.27",
    "zod": "npm:zod@^3.24.2",
    "@aws-sdk/client-s3": "npm:@aws-sdk/client-s3@3.797.0",
    "@aws-sdk/client-sqs": "npm:@aws-sdk/client-sqs@3.797.0",
    "@codemirror/commands": "npm:@codemirror/commands@^6.8.1",
    "@codemirror/language": "npm:@codemirror/language@^6.11.3",
    "@codemirror/lang-json": "npm:@codemirror/lang-json@^6.0.2",
    "@codemirror/state": "npm:@codemirror/state@^6.5.2",
    "@codemirror/theme-one-dark": "npm:@codemirror/theme-one-dark@^6.1.3",
    "@codemirror/view": "npm:@codemirror/view@^6.38.6",
    "winston": "npm:winston@^3.12.0",
    "winston-cloudwatch": "npm:winston-cloudwatch@^6.2.0"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "npm:preact",
    "lib": ["deno.unstable", "dom"]
  },
  "deploy": {
    "org": "briansimoni",
    "app": "weewoo-study"
  }
}
